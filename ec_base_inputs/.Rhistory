library(tidyverse)
library (MASS)
library (ISLR2)
library(rsample)
set.seed (1)
x <- rnorm (100)
y <- x - 2 * x^2 + rnorm (100)
data <- data.frame(x, y)
View(data)
scatter <- data %>%
ggplot(aes(x, y)) +
geom_point()
scatter
install.packages("boot")
library(boot)
reg1 <- lm(y ~ x, data)
summary(reg1)
reg3 <- lm(y ~ poly(x, 3), data)
summary(reg3)
reg2 <- lm(y ~ poly(x, 2), data)
summary(reg2)
reg4 <- lm(y ~ poly(x, 4), data)
summary(reg4)
reg1 <- glm(y ~ x, data)
?glm()
glm.fit <- glm(y ~ x, data)
glm.fit <- glm(y ~ x, data = data)
summary(glm.fit)
# adj R2 = 0.045; p-value = 0.019
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
glm.fit <- glm(y ~ poly(x, 2), data)
glm.fit <- glm(y ~ poly(x, 2), data = data)
summary(glm.fit)
# adj R2 = 0.873; p-value < 2.2 e-16
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
# loocv errors:
glm.fit <- glm(y ~ poly(x, 3), data = data)
summary(glm.fit)
# adj R2 = 0.8691; p-value < 2.2 e-16
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
glm.fit <- glm(y ~ poly(x, 4), data = data)
summary(glm.fit)
# adj R2 = 0.8701; p-value < 2.2 e-16
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
glm.fit <- glm(y ~ x, data = data)
summary(glm.fit)
# adj R2 = 0.045; p-value = 0.019
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
set.seed(138)
# i. Y = β0 + β1X + ϵ
glm.fit <- glm(y ~ x, data = data)
summary(glm.fit)
# adj R2 = 0.045; p-value = 0.019
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
set.seed(2)
# i. Y = β0 + β1X + ϵ
glm.fit <- glm(y ~ x, data = data)
summary(glm.fit)
# adj R2 = 0.045; p-value = 0.019
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
glm.fit <- glm(y ~ poly(x, 2), data = data)
summary(glm.fit)
# adj R2 = 0.873; p-value < 2.2 e-16
cv.err <- cv.glm(data, glm.fit)
cv.err$delta
?rowSums
library(dplyr)
# input_number <- 1
folders <- Sys.glob("input*")
print(folders)
for (input_folder in folders) {
init_cohort <- read.csv(paste0(input_folder,'/',"init_cohort.csv"))
#### initial cohort ####
# init_cohort <- read.csv("./init_cohort.csv")
# init_cohort <- read.csv(paste0("input", input_number, "/init_cohort.csv"))
# split into rows, divide counts by 5, regroup
init_cohort <- init_cohort %>%
mutate(age_min = as.numeric(sub("_(.*)", "", agegrp)),
age_max = as.numeric(sub("^(.*?)_", "", agegrp))) %>%
select(-agegrp) %>%
full_join(., expand.grid(block = unique(.$block),
sex = unique(.$sex),
oud = unique(.$oud),
age = as.numeric(c(min(.$age_min):max(.$age_max))))) %>%
filter(age >= age_min,
age <= age_max) %>%
select(-c(age_min, age_max)) %>%
mutate(counts = counts/5,
agegrp = cut(age, seq(9, 100, 2), labels = paste0(seq(10, 98, 2), "_", seq(11, 99, 2)))) %>%
group_by(agegrp, block, sex, oud) %>%
summarise(counts = sum(counts))
# re-arrange
init_cohort <- init_cohort %>%
arrange(factor(block, levels = c("No_Treatment", "Buprenorphine", "Naltrexone", "Methadone", "Detox",
"Post-Buprenorphine", "Post-Naltrexone", "Post-Methadone", "Post-Detox")),
agegrp, desc(sex), factor(oud, levels = c("Active_Noninjection", "Active_Injection",
"Nonactive_Noninjection", "Nonactive_Injection"))) %>%
select(block, agegrp, sex, oud, counts)
sum(init_cohort$counts)
write.csv(init_cohort, paste0(input_folder,'/',"init_cohort.csv"), row.names = F)
}
