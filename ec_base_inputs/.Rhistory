# this is a weird one
# (c) Split the data into a training set and a test set.
set.seed(123)
# Split the dataset using rsample
split_data <- initial_split(Auto, prop = 0.7)
train <- training(split_data)
test <- testing(split_data)
# (d) Perform LDA on the training data in order to predict mpg01
# using the variables that seemed most associated with mpg01 in
# (b). What is the test error of the model obtained?
lda.fit <- lda(mpg01 ~ cylinders + displacement + horsepower + weight,
data = train)
lda.fit
# Predict the outcomes for the test data
lda.pred <- predict(lda.fit, newdata = test)
# Calculate the error rate
error_rate <- mean(lda.pred$class != test$mpg01)
error_rate
# 11.02%
# (e) Perform QDA on the training data in order to predict mpg01
# using the variables that seemed most associated with mpg01 in
# (b). What is the test error of the model obtained?
qda.fit <- qda(mpg01 ~ cylinders + displacement + horsepower + weight,
data = train)
qda.fit
# Predict the outcomes for the test data
qda.pred <- predict(qda.fit, newdata = test)
# Calculate the error rate
error_rate <- mean(qda.pred$class != test$mpg01)
error_rate
